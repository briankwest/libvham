# libvham build — generated by autoconf from Makefile.in
#
# `make` builds the static lib + tests, `make test` runs them.
# Run `./configure` to (re)detect optional libraries.

CC       = @CC@
CFLAGS   = @CFLAGS@ -Wall -Wextra -Wpedantic -std=c11
CPPFLAGS = -Iinclude @VHAM_EXTRA_CFLAGS@ @VHAM_FEATURE_DEFS@ @CPPFLAGS@
LDFLAGS  = @LDFLAGS@
AR       = @AR@
RANLIB   = @RANLIB@

EXTRA_LIBS = @VHAM_EXTRA_LIBS@ @LIBS@

SRCS = src/codec.c src/md5.c src/auth.c src/regreq.c src/decoder.c \
       src/regrsp.c src/account.c src/cc.c src/sdp.c src/rtp.c \
       src/g711.c src/dtmf.c src/voice.c src/composites.c \
       src/passthrough.c src/oam.c src/codec_audio.c src/jitter.c \
       src/rtcp.c src/retx.c src/segment.c src/im.c src/gps.c \
       src/tokenstore.c src/h264.c src/srtp.c src/causes.c \
       src/envcfg.c src/nat.c src/voice_call.c \
       @VHAM_FEATURE_SRCS@
OBJS = $(SRCS:.c=.o)
LIB  = libvham.a

TEST_BIN = test/test_codec
TOOLS    = tools/vham-activate tools/vham-login tools/vham-call \
           tools/vham-session tools/vham-voice tools/vham-cli

.PHONY: all test clean distclean

all: $(LIB) $(TEST_BIN) $(TOOLS)

$(LIB): $(OBJS)
	$(AR) rcs $@ $(OBJS)
	$(RANLIB) $@

%.o: %.c
	$(CC) $(CFLAGS) $(CPPFLAGS) -c $< -o $@

$(TEST_BIN): test/test_codec.c test/mock_server.c test/mock_server.h $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) test/test_codec.c test/mock_server.c \
		$(LIB) $(EXTRA_LIBS) -o $@

tools/vham-activate: tools/vham-activate.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) -o $@

tools/vham-login: tools/vham-login.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) -o $@

tools/vham-call: tools/vham-call.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) -o $@

tools/vham-session: tools/vham-session.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) -o $@

tools/vham-voice: tools/vham-voice.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) -lm $(EXTRA_LIBS) -o $@

tools/vham-cli: tools/vham-cli.c $(LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) $< $(LIB) $(EXTRA_LIBS) -o $@

test: $(TEST_BIN)
	./$(TEST_BIN)

clean:
	rm -f $(OBJS) $(LIB) $(TEST_BIN) $(TOOLS)

distclean: clean
	rm -f Makefile config.log config.status
	rm -rf autom4te.cache build-aux
