# libvham — environment configuration
#
# Copy to `.env` (gitignored) and fill in your own values, or set
# these as real environment variables. Tools also accept --user /
# --pass / --server / --to flags which override.
#
# All keys are optional. Without them, tools fall back to public
# defaults (us.vham.net) and prompt for missing required arguments.

# Primary account
VHAM_USER=
VHAM_PASS=

# Secondary account — used by the two-account round-trip tests
VHAM_USER2=
VHAM_PASS2=

# Server. Accepts host:port or ip:port. Defaults to us.vham.net:10000.
# Known regional endpoints:
#   us.vham.net      LinkPoon US
#   th.vham.net      LinkPoon Thailand
#   linkpoon.com     LinkPoon China
VHAM_SERVER=us.vham.net:10000

# Common per-call defaults (override via --to, --tune, --group)
VHAM_TO=
VHAM_TUNE=
VHAM_GROUP=
